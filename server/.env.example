# mis-api environment — copy to server/.env and fill in.
# server/.env is consumed by docker-compose (env_file) at container start.

# Postgres over the shared docker network. Host is the container name
# `mis-postgres` (NOT localhost) because both containers share the
# maori-ink_default network. Swap PASSWORD for the real mis user password.
DATABASE_URL=postgres://mis:PASSWORD@mis-postgres:5432/mis

# Bearer token guarding the admin-only render route (/api/render/:id.png).
# Generate one:  openssl rand -hex 32
ADMIN_TOKEN=

# Port the Node server listens on inside the container.
PORT=8080
