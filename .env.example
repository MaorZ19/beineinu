# Postgres — self-hosted in Docker on your VPS, localhost-only.
#
# For LOCAL scripts (import, curation, rendering), connect through an SSH tunnel:
#   ssh -N -L 55432:127.0.0.1:5433 root@your-vps.example.com
# then use the tunnelled port:
#   DATABASE_URL=postgres://mis:PASSWORD@127.0.0.1:55432/mis
#
# For the on-VPS REST API container, it connects over the docker network:
#   DATABASE_URL=postgres://mis:PASSWORD@mis-postgres:5432/mis
DATABASE_URL=

# Anthropic — for the AI curation step (optional; curate by hand if you prefer)
ANTHROPIC_API_KEY=

# Path to the WhatsApp export consumed by scripts/import-chat.ts
CHAT_EXPORT_PATH=./_chat.txt

# The two couple participants EXACTLY as they appear in the export
# (sender names can include emoji — copy them verbatim from the file).
COUPLE_SENDER_A=
COUPLE_SENDER_B=
